  "keyFeatures": [
    "Offline-first architecture with Hive local database",
    "Barcode/QR code scanning for rapid product entry",
    "Bluetooth thermal printer integration",
    "Product inventory management with CRUD operations",
    "Real-time cart and checkout system",
    "Clean Architecture with BLoC state management",
    "Functional error handling with fpdart",
    "Customizable shop settings and receipt configuration"
  ],
  "publicApiSurface": [
    "ProductBloc - State management for product operations",
    "BillingBloc - State management for checkout and cart",
    "ShopBloc - State management for shop settings",
    "PrinterBloc - State management for printer connections",
    "GetProductsUseCase - Retrieve all products",
    "AddProductUseCase - Add new product to inventory",
    "UpdateProductUseCase - Update existing product",
    "DeleteProductUseCase - Remove product from inventory",
    "GetProductByBarcodeUseCase - Find product by barcode",
    "GetShopUseCase - Retrieve shop settings",
    "UpdateShopUseCase - Update shop configuration",
    "ProductRepository - Product data operations interface",
    "ShopRepository - Shop data operations interface",
    "PrinterRepository - Printer operations interface",
    "HiveDatabase - Local database initialization",
    "AppRoutes - Navigation configuration"
  ]
